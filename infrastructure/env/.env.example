# ============================================
# ADRISU KIDS - Produccion (.env para Docker)
# Copiar a .env y completar
# ============================================

# PostgreSQL
DB_PASSWORD=tu-password-seguro

# NextAuth
NEXTAUTH_SECRET=tu-secret-super-seguro

# Dominios
WMS_URL=https://admin.adriskids.com
TIENDA_URL=https://adriskids.com

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Resend (emails)
RESEND_API_KEY=
FROM_EMAIL=noreply@adriskids.com

# Telegram (notificaciones)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare R2 (almacenamiento de imagenes)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=adriskids-images
R2_PUBLIC_URL=https://images.adriskids.com

# Google Analytics
GA_MEASUREMENT_ID=

# Meta Pixel
META_PIXEL_ID=

# WhatsApp (consultas)
WHATSAPP_PHONE=51999111222

# imgBB (alternativa de imagenes)
IMGBB_API_KEY=
