generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  super_admin
  admin
  warehouse_manager
  warehouse_staff
  sales_manager
  sales_rep
  logistics_coordinator
  customer_service
  finance
  readonly
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  in_transit
  delivered
  cancelled
}

enum PaymentStatus {
  pending
  authorized
  captured
  partially_paid
  paid
  failed
  refunded
  voided
}

enum ShipmentStatus {
  pending
  label_created
  picked_up
  in_transit
  out_for_delivery
  delivered
  exception
  returned
}

enum ProductStatus {
  draft
  active
  archived
  discontinued
}

enum InvoiceStatus {
  draft
  issued
  sent
  paid
  overdue
  cancelled
  voided
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  export
  import
  approve
  reject
  execute
}

enum PickListStatus {
  draft
  assigned
  in_progress
  completed
  cancelled
}

enum ReturnStatus {
  pending
  inspecting
  reconditioned
  damaged
  disposed
  refunded
  cancelled
}

enum CycleCountStatus {
  scheduled
  in_progress
  completed
  cancelled
}

// ============================================================================
// IAM
// ============================================================================

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  phone        String?
  avatarUrl    String?   @map("avatar_url")
  role         UserRole  @default(readonly)
  isActive     Boolean   @default(true) @map("is_active")
  twoFactorSecret String? @map("two_factor_secret")
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions             Session[]
  placedOrders         Order[]            @relation("PlacedBy")
  managedWarehouses    Warehouse[]        @relation("Manager")
  orderedPurchaseOrders PurchaseOrder[]   @relation("OrderedBy")
  receivedReceipts     GoodsReceipt[]     @relation("ReceivedBy")
  auditTrails          AuditTrail[]       @relation("PerformedBy")
  notifications        NotificationQueue[] @relation("Recipient")
  assignedPickLists    PickList[]         @relation("PickListAssignee")
  assignedCycleCounts  CycleCount[]       @relation("CycleCountAssignee")
  qualityChecks        QualityCheck[]     @relation("QCAssigner")
  wishlists            Wishlist[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================================
// CATALOG
// ============================================================================

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  parentId    String?   @map("parent_id") @db.Uuid
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  attributes  Json      @default("[]")   // Atributos de variante: [{name, type, options}]
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id               String        @id @default(uuid()) @db.Uuid
  sku              String        @unique
  name             String
  slug             String        @unique
  model            String?
  description      String?
  shortDescription String?       @map("short_description")
  brand            String?
  categoryId       String?       @map("category_id") @db.Uuid
  status           ProductStatus @default(draft)
  tags             String[]      @default([])
  images           String[]      @default([])

  // Dimensiones
  height           Decimal?      @db.Decimal(10, 2)
  width            Decimal?      @db.Decimal(10, 2)
  depth            Decimal?      @db.Decimal(10, 2)

  // Atributos adicionales
  color            String?
  materials        String[]      @default([])
  recommendedAge   String?       @map("recommended_age")
  warrantyDays     Int?          @map("warranty_days")
  originCountry    String?       @map("origin_country")

  // Peso
  weight           Decimal?      @db.Decimal(10, 2)
  weightUnit       String?       @default("kg") @map("weight_unit")

  // Stock
  lowStockAlert    Int?          @map("low_stock_alert")

  // Configuracion de precios adicionales
  priceConfig      Json?         @map("price_config")

  // Popup de descuento
  discountPopup    Json?         @map("discount_popup")

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  publishedAt      DateTime?     @map("published_at")

  category  Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants  ProductVariant[]
  versions  ProductVersion[]
  suggestedProducts SuggestedProduct[]

  @@map("products")
}

model ProductVariant {
  id             String   @id @default(uuid()) @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  sku            String   @unique
  name           String
  attributes     Json     @default("{}")
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  costPrice      Decimal? @map("cost_price") @db.Decimal(10, 2)
  barcode        String?
  imageUrl       String?  @map("image_url")
  images         String[] @default([])                       // URLs de imgBB, max 5 por variante
  isActive       Boolean  @default(true) @map("is_active")
  lowStockAlert  Int?     @map("low_stock_alert")            // Umbral de alerta por variante
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory     Inventory[]
  orderItems    OrderItem[]
  priceListItems PriceListItem[]
  pickListItems PickListItem[]
  returnItems   ReturnItem[]
  cycleCountItems CycleCountItem[]
  lots          Lot[]
  serialNumbers SerialNumber[]
  qcItems       QualityCheckItem[]
  wishlists     Wishlist[]

  @@map("product_variants")
}

// ============================================================================
// VERSION HISTORY
// ============================================================================

model ProductVersion {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  version      Int      @default(1)
  snapshot     Json                              // Snapshot completo del producto
  diff         Json?                             // Resumen de cambios vs version anterior
  changeType   String   @default("manual") @map("change_type") // manual | auto
  authorId     String?  @map("author_id") @db.Uuid
  authorName   String?  @map("author_name")
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, version])
  @@map("product_versions")
}

// ============================================================================
// INVENTORY / WMS
// ============================================================================

model Inventory {
  id               String   @id @default(uuid()) @db.Uuid
  variantId        String   @map("variant_id") @db.Uuid
  warehouseId      String   @map("warehouse_id") @db.Uuid
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0) @map("reserved_quantity")
  availableQuantity Int     @default(0) @map("available_quantity")
  reorderPoint     Int      @default(10) @map("reorder_point")
  reorderQuantity  Int      @default(50) @map("reorder_quantity")
  lastCountedAt    DateTime? @map("last_counted_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([variantId, warehouseId])
  @@map("inventory")
}

model Warehouse {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  description String?
  address     Json     @default("{}")
  phone       String?
  email       String?
  managerId   String?  @map("manager_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  manager        User?               @relation("Manager", fields: [managerId], references: [id], onDelete: SetNull)
  locations      WarehouseLocation[]
  inventory      Inventory[]
  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  shipments      Shipment[]
  pickLists      PickList[]
  returns        Return[]
  cycleCounts    CycleCount[]
  lots           Lot[]
  serialNumbers  SerialNumber[]
  qualityChecks  QualityCheck[]

  @@map("warehouses")
}

model WarehouseLocation {
  id           String   @id @default(uuid()) @db.Uuid
  warehouseId  String   @map("warehouse_id") @db.Uuid
  parentId     String?  @map("parent_id") @db.Uuid
  code         String
  name         String
  locationType String   @default("shelf") @map("location_type")
  capacity     Int?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  warehouse Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  parent    WarehouseLocation? @relation("LocationTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  WarehouseLocation[] @relation("LocationTree")

  @@unique([warehouseId, code])
  @@map("warehouse_locations")
}

// ============================================================================
// PRICE LISTS
// ============================================================================

model PriceList {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  code        String    @unique
  description String?
  currency    String    @default("PEN")
  isDefault   Boolean   @default(false) @map("is_default")
  isActive    Boolean   @default(true) @map("is_active")
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items     PriceListItem[]
  customers Customer[]

  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid()) @db.Uuid
  priceListId String   @map("price_list_id") @db.Uuid
  variantId   String   @map("variant_id") @db.Uuid
  price       Decimal  @db.Decimal(10, 2)
  minQuantity Int      @default(1) @map("min_quantity")
  createdAt   DateTime @default(now()) @map("created_at")

  priceList PriceList      @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([priceListId, variantId, minQuantity])
  @@map("price_list_items")
}

// ============================================================================
// SALES / CRM
// ============================================================================

model Customer {
  id              String   @id @default(uuid()) @db.Uuid
  source          String   @default("wms") // 'wms' or 'store'
  customerType    String   @default("individual") @map("customer_type")
  email           String?
  phone           String?
  fullName        String   @map("full_name")
  companyName     String?  @map("company_name")
  taxId           String?  @map("tax_id")
  billingAddress  Json     @default("{}") @map("billing_address")
  shippingAddress Json     @default("{}") @map("shipping_address")
  priceListId     String?  @map("price_list_id") @db.Uuid
  creditLimit     Decimal  @default(0) @db.Decimal(12, 2) @map("credit_limit")
  currentBalance  Decimal  @default(0) @db.Decimal(12, 2) @map("current_balance")
  tags            String[] @default([])
  notes           String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  priceList PriceList? @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  orders    Order[]
  invoices  Invoice[]
  returns   Return[]

  @@map("customers")
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  orderNumber     String        @unique @map("order_number")
  source          String        @default("wms") // 'wms' or 'store'
  customerId      String        @map("customer_id") @db.Uuid
  placedBy        String?       @map("placed_by") @db.Uuid
  status          OrderStatus   @default(pending)
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  currency        String        @default("PEN")
  subtotal        Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2) @map("discount_amount")
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2) @map("tax_amount")
  shippingAmount  Decimal       @default(0) @db.Decimal(12, 2) @map("shipping_amount")
  total           Decimal       @default(0) @db.Decimal(12, 2)
  billingAddress  Json          @default("{}") @map("billing_address")
  shippingAddress Json          @default("{}") @map("shipping_address")
  notes           String?
  internalNotes   String?       @map("internal_notes")
  placedAt        DateTime?     @map("placed_at")
  confirmedAt     DateTime?     @map("confirmed_at")
  shippedAt       DateTime?     @map("shipped_at")
  deliveredAt     DateTime?     @map("delivered_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  placer         User?              @relation("PlacedBy", fields: [placedBy], references: [id], onDelete: SetNull)
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  invoices       Invoice[]
  shipments      Shipment[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  variantId  String? @map("variant_id") @db.Uuid
  productName String @map("product_name")
  variantName String @map("variant_name")
  sku        String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2) @map("unit_price")
  discountPercent Decimal @default(0) @db.Decimal(5, 2) @map("discount_percent")
  discountAmount  Decimal @default(0) @db.Decimal(10, 2) @map("discount_amount")
  total      Decimal @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  order   Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model OrderStatusHistory {
  id            String       @id @default(uuid()) @db.Uuid
  orderId       String       @map("order_id") @db.Uuid
  fromStatus    OrderStatus? @map("from_status")
  toStatus      OrderStatus  @map("to_status")
  changedBy     String?      @map("changed_by") @db.Uuid
  changedByType String       @default("user") @map("changed_by_type")
  reason        String?
  createdAt     DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

// ============================================================================
// INVOICING
// ============================================================================

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique @map("invoice_number")
  orderId       String?       @map("order_id") @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  status        InvoiceStatus @default(draft)
  currency      String        @default("PEN")
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(12, 2) @map("tax_amount")
  total         Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid    Decimal       @default(0) @db.Decimal(12, 2) @map("amount_paid")
  dueDate       DateTime?     @map("due_date")
  paidAt        DateTime?     @map("paid_at")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  description String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2) @map("unit_price")
  total     Decimal @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ============================================================================
// PURCHASING / SUPPLIERS
// ============================================================================

model Supplier {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  code         String   @unique
  supplierType String   @default("local") @map("supplier_type")
  contactName  String?  @map("contact_name")
  email        String?
  phone        String?
  address      Json     @default("{}")
  country      String?
  currency     String   @default("PEN")
  paymentTerms String?  @map("payment_terms")
  leadTimeDays Int      @default(7) @map("lead_time_days")
  rating       Int?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]

  @@map("suppliers")
}

model PurchaseOrder {
  id           String    @id @default(uuid()) @db.Uuid
  poNumber     String    @unique @map("po_number")
  supplierId   String    @map("supplier_id") @db.Uuid
  warehouseId  String    @map("warehouse_id") @db.Uuid
  orderedBy    String?   @map("ordered_by") @db.Uuid
  status       String    @default("draft")
  currency     String    @default("PEN")
  subtotal     Decimal   @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal   @default(0) @db.Decimal(12, 2) @map("tax_amount")
  total        Decimal   @default(0) @db.Decimal(12, 2)
  expectedDate DateTime? @map("expected_date")
  receivedDate DateTime? @map("received_date")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  supplier  Supplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  placer    User?         @relation("OrderedBy", fields: [orderedBy], references: [id], onDelete: SetNull)
  items     PurchaseOrderItem[]
  receipts  GoodsReceipt[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  variantId       String   @map("variant_id") @db.Uuid
  sku             String
  quantity        Int
  receivedQuantity Int    @default(0) @map("received_quantity")
  unitPrice       Decimal  @db.Decimal(10, 2) @map("unit_price")
  total           Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model GoodsReceipt {
  id              String   @id @default(uuid()) @db.Uuid
  receiptNumber   String   @unique @map("receipt_number")
  purchaseOrderId String?  @map("purchase_order_id") @db.Uuid
  warehouseId     String   @map("warehouse_id") @db.Uuid
  receivedBy      String?  @map("received_by") @db.Uuid
  supplierId      String?  @map("supplier_id") @db.Uuid
  status          String   @default("pending")
  receivedAt      DateTime @default(now()) @map("received_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  receiver      User?          @relation("ReceivedBy", fields: [receivedBy], references: [id], onDelete: SetNull)
  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items         GoodsReceiptItem[]

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id               String   @id @default(uuid()) @db.Uuid
  goodsReceiptId   String   @map("goods_receipt_id") @db.Uuid
  variantId        String   @map("variant_id") @db.Uuid
  expectedQuantity Int      @map("expected_quantity")
  receivedQuantity Int      @map("received_quantity")
  condition        String   @default("good")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@map("goods_receipt_items")
}

// ============================================================================
// LOGISTICS
// ============================================================================

model Shipment {
  id                String         @id @default(uuid()) @db.Uuid
  shipmentNumber    String         @unique @map("shipment_number")
  orderId           String?        @map("order_id") @db.Uuid
  warehouseId       String         @map("warehouse_id") @db.Uuid
  carrier           String
  trackingNumber    String?        @map("tracking_number")
  status            ShipmentStatus @default(pending)
  shippingAddress   Json           @default("{}") @map("shipping_address")
  weight            Decimal?       @db.Decimal(10, 2)
  cost              Decimal?       @db.Decimal(10, 2)
  estimatedDelivery DateTime?      @map("estimated_delivery")
  actualDelivery    DateTime?      @map("actual_delivery")
  notes             String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  order    Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  events   ShipmentEvent[]

  @@map("shipments")
}

model ShipmentEvent {
  id          String         @id @default(uuid()) @db.Uuid
  shipmentId  String         @map("shipment_id") @db.Uuid
  status      ShipmentStatus
  location    String?
  description String?
  eventTime   DateTime       @default(now()) @map("event_time")
  createdAt   DateTime       @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_events")
}

// ============================================================================
// AUDIT + NOTIFICATIONS + SYNC
// ============================================================================

model AuditTrail {
  id              String      @id @default(uuid()) @db.Uuid
  tableName       String      @map("table_name")
  recordId        String      @map("record_id") @db.Uuid
  action          AuditAction
  oldValues       Json        @default("{}") @map("old_values")
  newValues       Json        @default("{}") @map("new_values")
  changedFields   String[]    @default([]) @map("changed_fields")
  performedBy     String?     @map("performed_by") @db.Uuid
  performedByType String      @default("user") @map("performed_by_type")
  ipAddress       String?     @map("ip_address")
  createdAt       DateTime    @default(now()) @map("created_at")

  performer User? @relation("PerformedBy", fields: [performedBy], references: [id], onDelete: SetNull)

  @@map("audit_trail")
}

model NotificationQueue {
  id               String   @id @default(uuid()) @db.Uuid
  recipientId      String?  @map("recipient_id") @db.Uuid
  recipientEmail   String?  @map("recipient_email")
  subject          String?
  body             String
  channel          String?
  type             String   @default("info") // order, status, stock, info
  isRead           Boolean  @default(false) @map("is_read")
  status           String   @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")

  recipient User? @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("notification_queue")
}

// ============================================================================
// SYNC EVENTS (WMS -> Tienda)
// ============================================================================

model SyncEvent {
  id         String   @id @default(uuid()) @db.Uuid
  eventType  String   @map("event_type")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  payload    Json
  status     String   @default("pending") // pending, synced, failed
  retryCount Int      @default(0) @map("retry_count")
  errorMessage String? @map("error_message")
  createdAt  DateTime @default(now()) @map("created_at")
  syncedAt   DateTime? @map("synced_at")

  @@index([status, createdAt])
  @@map("sync_events")
}

// ============================================================================
// PICKING (Batch Picking for E-commerce)
// ============================================================================

model PickList {
  id              String        @id @default(uuid()) @db.Uuid
  pickNumber      String        @unique @map("pick_number")
  warehouseId     String        @map("warehouse_id") @db.Uuid
  assignedTo      String?       @map("assigned_to") @db.Uuid
  status          PickListStatus @default(draft)
  zone            String?       // optimization zone
  priority        Int           @default(0)
  startedAt       DateTime?     @map("started_at")
  completedAt     DateTime?     @map("completed_at")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  assignee  User?     @relation("PickListAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  items     PickListItem[]

  @@map("pick_lists")
}

model PickListItem {
  id            String   @id @default(uuid()) @db.Uuid
  pickListId    String   @map("pick_list_id") @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  variantId     String   @map("variant_id") @db.Uuid
  sku           String
  productName   String   @map("product_name")
  locationCode  String?  @map("location_code")
  quantity      Int
  scannedQty    Int      @default(0) @map("scanned_qty")
  status        String   @default("pending") // pending, picked, short
  scannedAt     DateTime? @map("scanned_at")
  createdAt     DateTime @default(now()) @map("created_at")

  pickList PickList     @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@map("pick_list_items")
}

// ============================================================================
// RETURNS / RMA
// ============================================================================

model Return {
  id              String       @id @default(uuid()) @db.Uuid
  returnNumber    String       @unique @map("return_number")
  orderId         String?      @map("order_id") @db.Uuid
  customerId      String       @map("customer_id") @db.Uuid
  warehouseId     String       @map("warehouse_id") @db.Uuid
  status          ReturnStatus @default(pending)
  reason          String?
  receivedAt      DateTime?    @map("received_at")
  inspectedAt     DateTime?    @map("inspected_at")
  resolvedAt      DateTime?    @map("resolved_at")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items     ReturnItem[]

  @@map("returns")
}

model ReturnItem {
  id          String   @id @default(uuid()) @db.Uuid
  returnId    String   @map("return_id") @db.Uuid
  variantId   String   @map("variant_id") @db.Uuid
  sku         String
  productName String   @map("product_name")
  quantity    Int
  condition   String   @default("good") // good, damaged, defective
  disposition String?  // restock, refurbish, dispose
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  return  Return        @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@map("return_items")
}

// ============================================================================
// CYCLE COUNTING
// ============================================================================

model CycleCount {
  id            String          @id @default(uuid()) @db.Uuid
  countNumber   String          @unique @map("count_number")
  warehouseId   String          @map("warehouse_id") @db.Uuid
  scheduledDate DateTime        @map("scheduled_date")
  status        CycleCountStatus @default(scheduled)
  zone          String?
  assignedTo    String?         @map("assigned_to") @db.Uuid
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  notes         String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  assignee  User?           @relation("CycleCountAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  items     CycleCountItem[]

  @@map("cycle_counts")
}

model CycleCountItem {
  id              String   @id @default(uuid()) @db.Uuid
  cycleCountId    String   @map("cycle_count_id") @db.Uuid
  variantId       String   @map("variant_id") @db.Uuid
  warehouseId     String   @map("warehouse_id") @db.Uuid
  locationCode    String?  @map("location_code")
  sku             String
  productName     String   @map("product_name")
  expectedQty     Int      @map("expected_qty")
  countedQty      Int?     @map("counted_qty")
  variance        Int?     // counted - expected
  status          String   @default("pending") // pending, counted, adjusted
  countedAt       DateTime? @map("counted_at")
  adjustedAt      DateTime? @map("adjusted_at")
  createdAt       DateTime @default(now()) @map("created_at")

  cycleCount CycleCount     @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@map("cycle_count_items")
}

// ============================================================================
// LOT/BATCH TRACKING
// ============================================================================

model Lot {
  id              String    @id @default(uuid()) @db.Uuid
  lotNumber       String    @unique @map("lot_number")
  variantId       String    @map("variant_id") @db.Uuid
  warehouseId     String    @map("warehouse_id") @db.Uuid
  quantity        Int       @default(0)
  reservedQty     Int       @default(0) @map("reserved_qty")
  availableQty    Int       @default(0) @map("available_qty")
  manufacturingDate DateTime? @map("manufacturing_date")
  expirationDate  DateTime? @map("expiration_date")
  receivedAt      DateTime  @default(now()) @map("received_at")
  status          String    @default("active") // active, expired, depleted, quarantined
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  movements LotMovement[]

  @@map("lots")
}

model LotMovement {
  id          String   @id @default(uuid()) @db.Uuid
  lotId       String   @map("lot_id") @db.Uuid
  type        String   // receive, ship, adjust, transfer, consume
  quantity    Int
  referenceId String?  @map("reference_id") // order_id, receipt_id, etc.
  referenceType String? @map("reference_type") // order, receipt, adjustment
  performedBy String?  @map("performed_by") @db.Uuid
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  lot Lot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@map("lot_movements")
}

// ============================================================================
// SERIAL NUMBER TRACKING
// ============================================================================

model SerialNumber {
  id            String   @id @default(uuid()) @db.Uuid
  serialNumber  String   @unique @map("serial_number")
  variantId     String   @map("variant_id") @db.Uuid
  warehouseId   String   @map("warehouse_id") @db.Uuid
  locationCode  String?  @map("location_code")
  status        String   @default("available") // available, reserved, sold, returned, damaged
  orderId       String?  @map("order_id") @db.Uuid
  receivedAt    DateTime @default(now()) @map("received_at")
  soldAt        DateTime? @map("sold_at")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@map("serial_numbers")
}

// ============================================================================
// QUALITY CONTROL
// ============================================================================

enum QCStatus {
  pending
  in_progress
  passed
  failed
  quarantined
}

model QualityCheck {
  id              String    @id @default(uuid()) @db.Uuid
  qcNumber        String    @unique @map("qc_number")
  type            String    // incoming, in_process, outgoing
  referenceId     String?   @map("reference_id") // receipt_id, order_id
  referenceType   String?   @map("reference_type") // receipt, order
  warehouseId     String    @map("warehouse_id") @db.Uuid
  inspectorId     String?   @map("inspector_id") @db.Uuid
  status          QCStatus @default(pending)
  result          String?   // pass, fail, conditional
  defectCount     Int       @default(0) @map("defect_count")
  notes           String?
  inspectedAt     DateTime? @map("inspected_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  inspector User?           @relation("QCAssigner", fields: [inspectorId], references: [id], onDelete: SetNull)
  items     QualityCheckItem[]

  @@map("quality_checks")
}

model QualityCheckItem {
  id            String   @id @default(uuid()) @db.Uuid
  qcId          String   @map("qc_id") @db.Uuid
  variantId     String   @map("variant_id") @db.Uuid
  quantity      Int
  passedQty     Int      @default(0) @map("passed_qty")
  failedQty     Int      @default(0) @map("failed_qty")
  defectType    String?  @map("defect_type") // cosmetic, functional, packaging, other
  defectNotes   String?  @map("defect_notes")
  disposition   String?  // accept, reject, rework, return
  createdAt     DateTime @default(now()) @map("created_at")

  qc      QualityCheck    @relation(fields: [qcId], references: [id], onDelete: Cascade)
  variant ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@map("quality_check_items")
}

// ============================================================================
// ABANDONED CHECKOUTS (RF-27)
// ============================================================================

model AbandonedCheckout {
  id              String   @id @default(uuid()) @db.Uuid
  sessionId       String?  @map("session_id")
  email           String?
  phone           String?
  name            String?
  items           Json     @default("[]") // array of {variantId, sku, name, price, quantity}
  subtotal        Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @default(0) @db.Decimal(12, 2)
  shippingAddress Json     @default("{}") @map("shipping_address")
  paymentMethod   String?  @map("payment_method")
  status          String   @default("abandoned") // abandoned, recovered, converted
  recoveredAt     DateTime? @map("recovered_at")
  convertedAt     DateTime? @map("converted_at")
  orderId         String?  @map("order_id") @db.Uuid
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("abandoned_checkouts")
}

// ============================================================================
// WISHLISTS (RF-30)
// ============================================================================

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
  @@map("wishlists")
}

// ============================================================================
// COUPONS (RF-34)
// ============================================================================
// NEWSLETTER (RF-40)
// ============================================================================

model NewsletterSubscriber {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  status    String   @default("active") // active, unsubscribed
  source    String?  // landing, checkout, footer
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

// ============================================================================
// TAX CONFIG (RF-54)
// ============================================================================

model TaxConfig {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  rate        Decimal @db.Decimal(5, 2) // 0.18 for IGV
  isDefault   Boolean @default(false) @map("is_default")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tax_configs")
}

// ============================================================================
// SUGGESTED PRODUCTS (Upsell en Checkout)
// ============================================================================

model SuggestedProduct {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  compareAtPrice  Decimal? @db.Decimal(10, 2) @map("compare_at_price")
  discountPercent Int      @default(0) @map("discount_percent")
  imageUrl        String?  @map("image_url")
  type            String   @default("custom") // "existing" | "custom"
  linkedProductId String?  @map("linked_product_id") @db.Uuid
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("suggested_products")
}

// ============================================================================
// BLOG POSTS
// ============================================================================

model BlogPost {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  content         String   @db.Text
  excerpt         String?
  coverImage      String?  @map("cover_image")
  authorId        String?  @map("author_id") @db.Uuid
  publishedAt     DateTime? @map("published_at")
  tags            String[]
  category        String?
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  isPublished     Boolean  @default(false) @map("is_published")
  viewCount       Int      @default(0) @map("view_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  author User? @relation(fields: [authorId], references: [id])

  @@map("blog_posts")
}
